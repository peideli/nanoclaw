# NanoClaw deployment configuration
# Copy this file to .env and fill in your values

# Bot identity
ASSISTANT_NAME=assistant

# WebChat
WEB_ENABLED=true
WEB_PORT=3000
WEB_JWT_SECRET=<change-me-random-string>

# Agent engine (Mini-Agent with OpenAI-compatible API)
AGENT_API_BASE=https://api.minimax.io/v1
AGENT_API_KEY=<your-minimax-api-key>
AGENT_MODEL=MiniMax-M2.5

# Optional: task classifier (for session rotation)
# CLASSIFIER_API_BASE=https://api.moonshot.cn/v1
# CLASSIFIER_API_KEY=<your-kimi-api-key>
# CLASSIFIER_MODEL=moonshot-v1-8k

# Optional: monthly token quota per user (default 500000)
# DEFAULT_MONTHLY_QUOTA=500000

# Call quality skill (通话质检)
# VOLC_ASR_APP_KEY=<your-volc-asr-app-key>
# VOLC_ASR_ACCESS_KEY=<your-volc-asr-access-key>
# DASHSCOPE_API_KEY=<your-dashscope-api-key>
